# Copy this file to .env (in the app/ directory) and fill in real values.
# NEVER commit a file with real secrets to git.
# In production, all secrets come from AWS Secrets Manager — not this file.

# ── Database ──────────────────────────────────────────────────────────────────
# For local Docker Compose: these must match compose.yml db service config.
# For production: set DATABASE_URL instead (App Runner reads it from Secrets Manager).
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=replace-with-db-user
POSTGRES_PASSWORD=replace-with-strong-password-min-24-chars
POSTGRES_DB=littleloot

# Or set the full URL (takes priority over individual vars above):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-string
ALGORITHM=HS256

# ── Cloudinary ────────────────────────────────────────────────────────────────
# From https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Test mode keys from https://dashboard.razorpay.com/app/keys
# Switch to Live Mode keys only after full QA and before first real transaction.
RAZORPAY_KEY_ID=rzp_test_replace_with_your_key_id
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-key-secret
# Webhook secret from https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=replace-with-your-webhook-secret

# ── Environment ───────────────────────────────────────────────────────────────
# "development" → /docs enabled, secure cookie not enforced.
# "production"  → /docs disabled, secure cookie required, RESEND required.
ENVIRONMENT=development

# Comma-separated list of your frontend origin(s).
# Production: ALLOWED_ORIGINS=https://littlelootgifts.com,https://www.littlelootgifts.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Required in production for forgot-password emails to actually send.
# Sign up at https://resend.com → add your domain → generate API key.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@littlelootgifts.com
FRONTEND_URL=http://localhost:3000
